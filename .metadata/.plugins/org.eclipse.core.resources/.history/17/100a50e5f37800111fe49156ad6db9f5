package com.coforge;

import java.util.LinkedList;
import java.util.Iterator;

/**
 * Hello world!
 */
public class App {
    public static void main(String[] args) {
       LinkedList<String> namesList = new LinkedList<String>();
       namesList.add("aniket");
       namesList.add("aniket");
       namesList.add("anddket");
       namesList.add("amuet");
       namesList.add(null);
       namesList.add(null);
       System.out.println(namesList);
       System.out.println("----------------------");
       namesList.addFirst("pooja");
       namesList.addFirst("kala");
       System.out.println(namesList);
       System.out.println("----------------------");
       Iterator<String> itr = namesList.iterator();
       while(itr.hasNext())
       {
    	   System.out.println(itr.next());
       }
       System.out.println("----------------------");
       itr = namesList.descendingIterator();
       while(itr.hasNext())
       {
    	   System.out.println(itr.next());
       }
       System.out.println("----------------------");
       System.out.println(namesList.element());
       // listiterator , descednigiterator ,
      
       
    }
}
